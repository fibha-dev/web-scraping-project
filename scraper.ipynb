import requests
from bs4 import BeautifulSoup
import pandas as pd
import time

def scrape_books_all_pages():
    """
    Scrapes all pages from BooksToScrape.
    Extracts title, price, rating, and page number.
    """

    base_url = "http://books.toscrape.com/catalogue/page-{}.html"

    data = []
    page = 1

    print("Starting scraping...")

    while True:
        url = base_url.format(page)
        response = requests.get(url)

        # Stop when page doesn't exist
        if response.status_code != 200:
            print(f"No more pages. Stopped at page {page}.")
            break

        soup = BeautifulSoup(response.text, "html.parser")
        books = soup.find_all("article", class_="product_pod")

        if not books:
            break

        print(f"Scraping page {page}...")

        for book in books:
            # Extract title
            title = book.h3.a["title"]

            # Extract price
            price = book.find("p", class_="price_color").text

            # Extract rating from class
            rating_class = book.find("p", class_="star-rating")["class"]
            rating = rating_class[1]

            data.append({
                "title": title,
                "price": price,
                "rating": rating,
                "page": page
            })

        page += 1
        time.sleep(1)  # Ethical delay

    df = pd.DataFrame(data)
    print(f"Total books scraped: {len(df)}")

    return df


if __name__ == "__main__":
    final_df = scrape_books_all_pages()

    # Save to CSV
    final_df.to_csv("data.csv", index=False)

    print("CSV saved as data.csv")
